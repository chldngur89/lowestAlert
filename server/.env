# Server Port
PORT=3001

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/lowestalert?schema=public"

# ============================================
# REDIS CACHE
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# CRAWLER MODE
# ============================================
PORT=3001

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/lowestalert?schema=public"


# ============================================
# CRAWLER MODE
# ============================================
# local-browser: Visible browser (RECOMMENDED - uses your IP)
# home-proxy: HTTP proxy (no browser, simpler sites only)
# puppeteer: Headless browser (needs residential proxy)
CRAWLER_MODE=local-browser

# ============================================
# HOME PROXY (for home-proxy mode)
# ============================================
PROXY_URL=http://localhost:8080

# ============================================
# RESIDENTIAL PROXY (for puppeteer mode)
# ============================================
RESIDENTIAL_PROXY_ENABLED=false
RESIDENTIAL_PROXY_HOST=
RESIDENTIAL_PROXY_PORT=
RESIDENTIAL_PROXY_USERNAME=
RESIDENTIAL_PROXY_PASSWORD=
